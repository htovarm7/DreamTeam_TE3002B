<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="so101">

  <!-- use_sim:=true  → GazeboSystem hardware plugin (Gazebo Classic)  -->
  <!-- use_sim:=false → mock_components (feetech_bridge handles physical) -->
  <xacro:arg name="use_sim" default="false"/>

  <xacro:include filename="$(find so101_description)/urdf/so101.ros2_control.xacro"/>

  <xacro:if value="$(arg use_sim)">
    <xacro:include filename="$(find so101_description)/urdf/so101.gazebo.xacro"/>
  </xacro:if>

  <xacro:property name="mesh_pkg" value="package://so101_description/meshes"/>

  <!-- ── Materials ─────────────────────────────────────── -->
  <material name="3d_printed">
    <color rgba="1.0 0.82 0.12 1.0"/>
  </material>
  <material name="sts3215">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>

  <!-- ── World anchor ──────────────────────────────────── -->
  <link name="world"/>

  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child  link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ── base_link ─────────────────────────────────────── -->
  <link name="base_link">
    <inertial>
      <origin xyz="0.0137179 -5.19711e-05 0.0334843" rpy="0 0 0"/>
      <mass value="0.147"/>
      <inertia ixx="0.000114686" ixy="-4.59787e-07" ixz="4.97151e-06"
               iyy="0.000136117" iyz="9.75275e-08" izz="0.000130364"/>
    </inertial>
    <visual>
      <origin xyz="-0.00636471 -9.94414e-05 -0.0024" rpy="1.5708 0 1.5708"/>
      <geometry><mesh filename="${mesh_pkg}/base_motor_holder_so101_v1.stl"/></geometry>
      <material name="3d_printed"/>
    </visual>
    <collision>
      <origin xyz="-0.00636471 -9.94414e-05 -0.0024" rpy="1.5708 0 1.5708"/>
      <geometry><mesh filename="${mesh_pkg}/base_motor_holder_so101_v1.stl"/></geometry>
    </collision>
    <visual>
      <origin xyz="-0.00636471 -8.97657e-09 -0.0024" rpy="1.5708 0 1.5708"/>
      <geometry><mesh filename="${mesh_pkg}/base_so101_v2.stl"/></geometry>
      <material name="3d_printed"/>
    </visual>
    <collision>
      <origin xyz="-0.00636471 -8.97657e-09 -0.0024" rpy="1.5708 0 1.5708"/>
      <geometry><mesh filename="${mesh_pkg}/base_so101_v2.stl"/></geometry>
    </collision>
    <visual>
      <origin xyz="0.0263353 -8.97657e-09 0.0437" rpy="0 0 0"/>
      <geometry><mesh filename="${mesh_pkg}/sts3215_03a_v1.stl"/></geometry>
      <material name="sts3215"/>
    </visual>
    <collision>
      <origin xyz="0.0263353 -8.97657e-09 0.0437" rpy="0 0 0"/>
      <geometry><mesh filename="${mesh_pkg}/sts3215_03a_v1.stl"/></geometry>
    </collision>
    <visual>
      <origin xyz="-0.0309827 -0.000199441 0.0474" rpy="1.5708 0 1.5708"/>
      <geometry><mesh filename="${mesh_pkg}/waveshare_mounting_plate_so101_v2.stl"/></geometry>
      <material name="3d_printed"/>
    </visual>
    <collision>
      <origin xyz="-0.0309827 -0.000199441 0.0474" rpy="1.5708 0 1.5708"/>
      <geometry><mesh filename="${mesh_pkg}/waveshare_mounting_plate_so101_v2.stl"/></geometry>
    </collision>
  </link>

  <!-- ── Joint 1: shoulder_pan ─────────────────────────── -->
  <joint name="shoulder_pan" type="revolute">
    <parent link="base_link"/>
    <child  link="shoulder_link"/>
    <origin xyz="0.0388353 -8.97657e-09 0.0624" rpy="3.14159 0 -3.14159"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.91986" upper="1.91986" effort="10" velocity="2.0"/>
    <dynamics damping="0.6" friction="0.052"/>
  </joint>

  <!-- ── shoulder_link ─────────────────────────────────── -->
  <link name="shoulder_link">
    <inertial>
      <origin xyz="-0.0307604 -1.66727e-05 -0.0252713" rpy="0 0 0"/>
      <mass value="0.100006"/>
      <inertia ixx="8.3759e-05" ixy="7.55525e-08" ixz="-1.16342e-06"
               iyy="8.10403e-05" iyz="1.54663e-07" izz="2.39783e-05"/>
    </inertial>
    <visual>
      <origin xyz="-0.0303992 0.000422241 -0.0417" rpy="1.5708 1.5708 0"/>
      <geometry><mesh filename="${mesh_pkg}/sts3215_03a_v1.stl"/></geometry>
      <material name="sts3215"/>
    </visual>
    <collision>
      <origin xyz="-0.0303992 0.000422241 -0.0417" rpy="1.5708 1.5708 0"/>
      <geometry><mesh filename="${mesh_pkg}/sts3215_03a_v1.stl"/></geometry>
    </collision>
    <visual>
      <origin xyz="-0.0675992 -0.000177759 0.0158499" rpy="1.5708 -1.5708 0"/>
      <geometry><mesh filename="${mesh_pkg}/motor_holder_so101_base_v1.stl"/></geometry>
      <material name="3d_printed"/>
    </visual>
    <collision>
      <origin xyz="-0.0675992 -0.000177759 0.0158499" rpy="1.5708 -1.5708 0"/>
      <geometry><mesh filename="${mesh_pkg}/motor_holder_so101_base_v1.stl"/></geometry>
    </collision>
    <visual>
      <origin xyz="0.0122008 2.22413e-05 0.0464" rpy="-1.5708 0 0"/>
      <geometry><mesh filename="${mesh_pkg}/rotation_pitch_so101_v1.stl"/></geometry>
      <material name="3d_printed"/>
    </visual>
    <collision>
      <origin xyz="0.0122008 2.22413e-05 0.0464" rpy="-1.5708 0 0"/>
      <geometry><mesh filename="${mesh_pkg}/rotation_pitch_so101_v1.stl"/></geometry>
    </collision>
  </link>

  <!-- ── Joint 2: shoulder_lift ────────────────────────── -->
  <joint name="shoulder_lift" type="revolute">
    <parent link="shoulder_link"/>
    <child  link="upper_arm_link"/>
    <origin xyz="-0.0303992 -0.0182778 -0.0542" rpy="-1.5708 -1.5708 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.74533" upper="1.74533" effort="10" velocity="2.0"/>
    <dynamics damping="0.6" friction="0.052"/>
  </joint>

  <!-- ── upper_arm_link ────────────────────────────────── -->
  <link name="upper_arm_link">
    <inertial>
      <origin xyz="-0.0898471 -0.00838224 0.0184089" rpy="0 0 0"/>
      <mass value="0.103"/>
      <inertia ixx="4.08002e-05" ixy="-1.97819e-05" ixz="-4.03016e-08"
               iyy="0.000147318" iyz="8.97326e-09" izz="0.000142487"/>
    </inertial>
    <visual>
      <origin xyz="-0.11257 -0.0155 0.0187" rpy="-3.14159 0 -1.5708"/>
      <geometry><mesh filename="${mesh_pkg}/sts3215_03a_v1.stl"/></geometry>
      <material name="sts3215"/>
    </visual>
    <collision>
      <origin xyz="-0.11257 -0.0155 0.0187" rpy="-3.14159 0 -1.5708"/>
      <geometry><mesh filename="${mesh_pkg}/sts3215_03a_v1.stl"/></geometry>
    </collision>
    <visual>
      <origin xyz="-0.065085 0.012 0.0182" rpy="3.14159 0 0"/>
      <geometry><mesh filename="${mesh_pkg}/upper_arm_so101_v1.stl"/></geometry>
      <material name="3d_printed"/>
    </visual>
    <collision>
      <origin xyz="-0.065085 0.012 0.0182" rpy="3.14159 0 0"/>
      <geometry><mesh filename="${mesh_pkg}/upper_arm_so101_v1.stl"/></geometry>
    </collision>
  </link>

  <!-- ── Joint 3: elbow_flex ───────────────────────────── -->
  <joint name="elbow_flex" type="revolute">
    <parent link="upper_arm_link"/>
    <child  link="lower_arm_link"/>
    <origin xyz="-0.11257 -0.028 0" rpy="0 0 1.5708"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.69" upper="1.69" effort="10" velocity="2.0"/>
    <dynamics damping="0.6" friction="0.052"/>
  </joint>

  <!-- ── lower_arm_link ────────────────────────────────── -->
  <link name="lower_arm_link">
    <inertial>
      <origin xyz="-0.0980701 0.00324376 0.0182831" rpy="0 0 0"/>
      <mass value="0.104"/>
      <inertia ixx="2.87438e-05" ixy="7.41152e-06" ixz="1.26409e-06"
               iyy="0.000159844" iyz="-4.90188e-08" izz="0.00014529"/>
    </inertial>
    <visual>
      <origin xyz="-0.0648499 -0.032 0.0182" rpy="3.14159 0 0"/>
      <geometry><mesh filename="${mesh_pkg}/under_arm_so101_v1.stl"/></geometry>
      <material name="3d_printed"/>
    </visual>
    <collision>
      <origin xyz="-0.0648499 -0.032 0.0182" rpy="3.14159 0 0"/>
      <geometry><mesh filename="${mesh_pkg}/under_arm_so101_v1.stl"/></geometry>
    </collision>
    <visual>
      <origin xyz="-0.0648499 -0.032 0.018" rpy="-3.14159 0 0"/>
      <geometry><mesh filename="${mesh_pkg}/motor_holder_so101_wrist_v1.stl"/></geometry>
      <material name="3d_printed"/>
    </visual>
    <collision>
      <origin xyz="-0.0648499 -0.032 0.018" rpy="-3.14159 0 0"/>
      <geometry><mesh filename="${mesh_pkg}/motor_holder_so101_wrist_v1.stl"/></geometry>
    </collision>
    <visual>
      <origin xyz="-0.1224 0.0052 0.0187" rpy="-3.14159 0 -3.14159"/>
      <geometry><mesh filename="${mesh_pkg}/sts3215_03a_v1.stl"/></geometry>
      <material name="sts3215"/>
    </visual>
    <collision>
      <origin xyz="-0.1224 0.0052 0.0187" rpy="-3.14159 0 -3.14159"/>
      <geometry><mesh filename="${mesh_pkg}/sts3215_03a_v1.stl"/></geometry>
    </collision>
  </link>

  <!-- ── Joint 4: wrist_flex ───────────────────────────── -->
  <joint name="wrist_flex" type="revolute">
    <parent link="lower_arm_link"/>
    <child  link="wrist_link"/>
    <origin xyz="-0.1349 0.0052 0" rpy="0 0 -1.5708"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.65806" upper="1.65806" effort="10" velocity="3.0"/>
    <dynamics damping="0.6" friction="0.052"/>
  </joint>

  <!-- ── wrist_link ────────────────────────────────────── -->
  <link name="wrist_link">
    <inertial>
      <origin xyz="-0.000103312 -0.0386143 0.0281156" rpy="0 0 0"/>
      <mass value="0.079"/>
      <inertia ixx="3.68263e-05" ixy="1.7893e-08" ixz="-5.28128e-08"
               iyy="2.5391e-05" iyz="3.6412e-06" izz="2.1e-05"/>
    </inertial>
    <visual>
      <origin xyz="8.32667e-17 -0.0424 0.0306" rpy="1.5708 1.5708 0"/>
      <geometry><mesh filename="${mesh_pkg}/sts3215_03a_no_horn_v1.stl"/></geometry>
      <material name="sts3215"/>
    </visual>
    <collision>
      <origin xyz="8.32667e-17 -0.0424 0.0306" rpy="1.5708 1.5708 0"/>
      <geometry><mesh filename="${mesh_pkg}/sts3215_03a_no_horn_v1.stl"/></geometry>
    </collision>
    <visual>
      <origin xyz="0 -0.028 0.0181" rpy="-1.5708 -1.5708 0"/>
      <geometry><mesh filename="${mesh_pkg}/wrist_roll_pitch_so101_v2.stl"/></geometry>
      <material name="3d_printed"/>
    </visual>
    <collision>
      <origin xyz="0 -0.028 0.0181" rpy="-1.5708 -1.5708 0"/>
      <geometry><mesh filename="${mesh_pkg}/wrist_roll_pitch_so101_v2.stl"/></geometry>
    </collision>
  </link>

  <!-- ── Joint 5: wrist_roll ───────────────────────────── -->
  <joint name="wrist_roll" type="revolute">
    <parent link="wrist_link"/>
    <child  link="gripper_link"/>
    <origin xyz="5.55112e-17 -0.0611 0.0181" rpy="1.5708 0.0486795 3.14159"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.74385" upper="2.84121" effort="10" velocity="3.0"/>
    <dynamics damping="0.6" friction="0.052"/>
  </joint>

  <!-- ── gripper_link ──────────────────────────────────── -->
  <link name="gripper_link">
    <inertial>
      <origin xyz="0.000213627 0.000245138 -0.025187" rpy="0 0 0"/>
      <mass value="0.087"/>
      <inertia ixx="2.75087e-05" ixy="-3.35241e-07" ixz="-5.7352e-06"
               iyy="4.33657e-05" iyz="-5.17847e-08" izz="3.45059e-05"/>
    </inertial>
    <visual>
      <origin xyz="0.0077 0.0001 -0.0234" rpy="-1.5708 0 0"/>
      <geometry><mesh filename="${mesh_pkg}/sts3215_03a_v1.stl"/></geometry>
      <material name="sts3215"/>
    </visual>
    <collision>
      <origin xyz="0.0077 0.0001 -0.0234" rpy="-1.5708 0 0"/>
      <geometry><mesh filename="${mesh_pkg}/sts3215_03a_v1.stl"/></geometry>
    </collision>
    <visual>
      <origin xyz="8.32667e-17 -0.000218214 0.000949706" rpy="-3.14159 0 0"/>
      <geometry><mesh filename="${mesh_pkg}/wrist_roll_follower_so101_v1.stl"/></geometry>
      <material name="3d_printed"/>
    </visual>
    <collision>
      <origin xyz="8.32667e-17 -0.000218214 0.000949706" rpy="-3.14159 0 0"/>
      <geometry><mesh filename="${mesh_pkg}/wrist_roll_follower_so101_v1.stl"/></geometry>
    </collision>
  </link>

  <!-- ── Joint 6: gripper ──────────────────────────────── -->
  <joint name="gripper" type="revolute">
    <parent link="gripper_link"/>
    <child  link="moving_jaw_link"/>
    <origin xyz="0.0202 0.0188 -0.0234" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.174533" upper="1.74533" effort="10" velocity="3.0"/>
    <dynamics damping="0.6" friction="0.052"/>
  </joint>

  <!-- ── moving_jaw_link ───────────────────────────────── -->
  <link name="moving_jaw_link">
    <inertial>
      <origin xyz="-0.00157495 -0.0300244 0.0192755" rpy="0 0 0"/>
      <mass value="0.012"/>
      <inertia ixx="6.61427e-06" ixy="-3.19807e-07" ixz="-5.90717e-09"
               iyy="1.89032e-06" iyz="-1.09945e-07" izz="5.28738e-06"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.0189" rpy="0 0 0"/>
      <geometry><mesh filename="${mesh_pkg}/moving_jaw_so101_v1.stl"/></geometry>
      <material name="3d_printed"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.0189" rpy="0 0 0"/>
      <geometry><mesh filename="${mesh_pkg}/moving_jaw_so101_v1.stl"/></geometry>
    </collision>
  </link>

  <!-- ── TCP (tool-center point) ───────────────────────── -->
  <joint name="tcp_joint" type="fixed">
    <parent link="gripper_link"/>
    <child  link="tcp"/>
    <origin xyz="-0.0079 -0.000218121 -0.0981274" rpy="0 3.14159 0"/>
  </joint>
  <link name="tcp"/>

</robot>
