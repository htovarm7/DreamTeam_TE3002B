<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="so_arm100">

  <!-- ========================================================
       SO-ARM100  —  6-DOF + gripper
       Joints: base_rotation, shoulder, elbow, wrist_pitch,
               wrist_roll, jaw (2 mirrored fingers)
       All dimensions in metres, masses in kg.
  ======================================================== -->

  <!-- Gazebo / ros2_control plugin -->
  <xacro:include filename="$(find so_arm100_description)/urdf/so_arm100.gazebo.xacro"/>
  <xacro:include filename="$(find so_arm100_description)/urdf/so_arm100.ros2_control.xacro"/>

  <!-- ───────── Materials ───────── -->
  <material name="dark_grey">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="light_grey">
    <color rgba="0.7 0.7 0.7 1.0"/>
  </material>
  <material name="white">
    <color rgba="0.9 0.9 0.9 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.05 0.05 0.05 1.0"/>
  </material>
  <material name="orange">
    <color rgba="1.0 0.5 0.0 1.0"/>
  </material>

  <!-- ───────── Macro: box inertia ───────── -->
  <xacro:macro name="box_inertia" params="m x y z">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(y*y+z*z)/12}" ixy="0" ixz="0"
               iyy="${m*(x*x+z*z)/12}" iyz="0"
               izz="${m*(x*x+y*y)/12}"/>
    </inertial>
  </xacro:macro>

  <!-- ───────── World / base_footprint ───────── -->
  <link name="world"/>

  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child  link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ───────── Base link ───────── -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry><cylinder radius="0.055" length="0.05"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry><cylinder radius="0.055" length="0.05"/></geometry>
    </collision>
    <xacro:box_inertia m="0.5" x="0.11" y="0.11" z="0.05"/>
  </link>

  <!-- ───────── Joint 1: Base rotation (yaw) ───────── -->
  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child  link="link1"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${-pi}" upper="${pi}" effort="10" velocity="2.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <link name="link1">
    <visual>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry><box size="0.05 0.05 0.08"/></geometry>
      <material name="light_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry><box size="0.05 0.05 0.08"/></geometry>
    </collision>
    <xacro:box_inertia m="0.2" x="0.05" y="0.05" z="0.08"/>
  </link>

  <!-- ───────── Joint 2: Shoulder pitch ───────── -->
  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child  link="link2"/>
    <origin xyz="0 0 0.085" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${-pi/2}" upper="${pi/2}" effort="10" velocity="2.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <link name="link2">
    <visual>
      <origin xyz="0 0 0.065" rpy="0 0 0"/>
      <geometry><box size="0.04 0.04 0.13"/></geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.065" rpy="0 0 0"/>
      <geometry><box size="0.04 0.04 0.13"/></geometry>
    </collision>
    <xacro:box_inertia m="0.18" x="0.04" y="0.04" z="0.13"/>
  </link>

  <!-- ───────── Joint 3: Elbow pitch ───────── -->
  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child  link="link3"/>
    <origin xyz="0 0 0.13" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${-pi*2/3}" upper="${pi*2/3}" effort="8" velocity="2.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <link name="link3">
    <visual>
      <origin xyz="0 0 0.055" rpy="0 0 0"/>
      <geometry><box size="0.038 0.038 0.11"/></geometry>
      <material name="light_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.055" rpy="0 0 0"/>
      <geometry><box size="0.038 0.038 0.11"/></geometry>
    </collision>
    <xacro:box_inertia m="0.14" x="0.038" y="0.038" z="0.11"/>
  </link>

  <!-- ───────── Joint 4: Wrist pitch ───────── -->
  <joint name="joint4" type="revolute">
    <parent link="link3"/>
    <child  link="link4"/>
    <origin xyz="0 0 0.11" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${-pi/2}" upper="${pi/2}" effort="5" velocity="3.0"/>
    <dynamics damping="0.05" friction="0.02"/>
  </joint>

  <link name="link4">
    <visual>
      <origin xyz="0 0 0.035" rpy="0 0 0"/>
      <geometry><box size="0.035 0.035 0.07"/></geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.035" rpy="0 0 0"/>
      <geometry><box size="0.035 0.035 0.07"/></geometry>
    </collision>
    <xacro:box_inertia m="0.10" x="0.035" y="0.035" z="0.07"/>
  </link>

  <!-- ───────── Joint 5: Wrist roll ───────── -->
  <joint name="joint5" type="revolute">
    <parent link="link4"/>
    <child  link="link5"/>
    <origin xyz="0 0 0.07" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${-pi}" upper="${pi}" effort="5" velocity="3.0"/>
    <dynamics damping="0.05" friction="0.02"/>
  </joint>

  <link name="link5">
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry><cylinder radius="0.020" length="0.05"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry><cylinder radius="0.020" length="0.05"/></geometry>
    </collision>
    <xacro:box_inertia m="0.06" x="0.04" y="0.04" z="0.05"/>
  </link>

  <!-- ───────── Gripper base ───────── -->
  <joint name="gripper_base_joint" type="fixed">
    <parent link="link5"/>
    <child  link="gripper_base"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
  </joint>

  <link name="gripper_base">
    <visual>
      <origin xyz="0 0 0.01" rpy="0 0 0"/>
      <geometry><box size="0.06 0.025 0.02"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.01" rpy="0 0 0"/>
      <geometry><box size="0.06 0.025 0.02"/></geometry>
    </collision>
    <xacro:box_inertia m="0.05" x="0.06" y="0.025" z="0.02"/>
  </link>

  <!-- ───────── Gripper finger left ───────── -->
  <joint name="gripper_left_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child  link="gripper_left"/>
    <origin xyz="-0.015 0 0.02" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.025" upper="0.0" effort="5" velocity="0.1"/>
    <dynamics damping="0.05" friction="0.01"/>
  </joint>

  <link name="gripper_left">
    <visual>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry><box size="0.01 0.018 0.04"/></geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry><box size="0.01 0.018 0.04"/></geometry>
    </collision>
    <xacro:box_inertia m="0.02" x="0.01" y="0.018" z="0.04"/>
  </link>

  <!-- ───────── Gripper finger right (mimic) ───────── -->
  <joint name="gripper_right_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child  link="gripper_right"/>
    <origin xyz="0.015 0 0.02" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/>
    <limit lower="-0.025" upper="0.0" effort="5" velocity="0.1"/>
    <mimic joint="gripper_left_joint" multiplier="1.0" offset="0.0"/>
    <dynamics damping="0.05" friction="0.01"/>
  </joint>

  <link name="gripper_right">
    <visual>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry><box size="0.01 0.018 0.04"/></geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry><box size="0.01 0.018 0.04"/></geometry>
    </collision>
    <xacro:box_inertia m="0.02" x="0.01" y="0.018" z="0.04"/>
  </link>

  <!-- ───────── Tool-center point ───────── -->
  <joint name="tcp_joint" type="fixed">
    <parent link="gripper_base"/>
    <child  link="tcp"/>
    <origin xyz="0 0 0.07" rpy="0 0 0"/>
  </joint>

  <link name="tcp"/>

  <!-- ───────── ZED2 Camera mount (fixed to link1 at ~eye height) ───────── -->
  <joint name="camera_mount_joint" type="fixed">
    <parent link="world"/>
    <child  link="zed2_base_link"/>
    <origin xyz="-0.35 0 0.30" rpy="0 0.4 0"/>
  </joint>

  <link name="zed2_base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.175 0.030 0.033"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.175 0.030 0.033"/></geometry>
    </collision>
    <xacro:box_inertia m="0.16" x="0.175" y="0.030" z="0.033"/>
  </link>

  <!-- Left optical frame (main RGB) -->
  <joint name="zed2_left_camera_joint" type="fixed">
    <parent link="zed2_base_link"/>
    <child  link="zed2_left_camera_frame"/>
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>
  <link name="zed2_left_camera_frame"/>

  <joint name="zed2_left_camera_optical_joint" type="fixed">
    <parent link="zed2_left_camera_frame"/>
    <child  link="zed2_left_camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
  <link name="zed2_left_camera_optical_frame"/>

</robot>
